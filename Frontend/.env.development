# Frontend Development Environment Configuration
# Omit VITE_API_BASE_URL so the browser calls same-origin /api/* and Vite (vite.config.js)
# proxies to the Node backend — avoids CORS and wrong-port issues.
# If you need a direct URL instead, uncomment:
# VITE_API_BASE_URL=http://127.0.0.1:3001
VITE_API_TIMEOUT=10000
VITE_AUTO_REFRESH_INTERVAL=60000

# Development Configuration
VITE_NODE_ENV=development

# CORS Configuration (Local Development)
VITE_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000
